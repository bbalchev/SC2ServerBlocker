<Window x:Name="mainWindow" x:Class="SC2ServerBlocker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SC2ServerBlocker"
        mc:Ignorable="d"
        Title="StarCraft 2 Server Blocker"
        Width="520"
        MinWidth="500"
        MinHeight="300"
        MaxHeight="520"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        PreviewKeyDown="OnWindowPreviewKeyDown"
        Closing="OnWindowClosing">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border x:Name="validationBanner"
                Grid.Row="0"
                Margin="0,0,0,10"
                Padding="10,8"
                CornerRadius="4"
                Visibility="Collapsed">
            <TextBlock x:Name="validationBannerText"
                       TextWrapping="Wrap"/>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Content="Region:" VerticalAlignment="Center" Padding="0"/>
            <ComboBox x:Name="serverList"
                      Grid.Column="1"
                      Margin="8,0,0,0"
                      DisplayMemberPath="DisplayName"
                      SelectionChanged="OnServerSelectionChanged"/>
        </Grid>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Margin="0,0,0,10">
            <Button x:Name="blockButton"
                    Content="Block"
                    ToolTip="Block selected region (Enter)"
                    MinWidth="80"
                    Padding="12,4"
                    Margin="0,0,8,0"
                    Click="OnServerBlocked"/>
            <Button x:Name="unblockButton"
                    Content="Unblock"
                    ToolTip="Unblock selected region (Ctrl+U)"
                    MinWidth="80"
                    Padding="12,4"
                    Margin="0,0,8,0"
                    Click="OnServerUnblocked"/>
            <Button x:Name="unblockAllButton"
                    Content="Unblock All"
                    ToolTip="Unblock all regions (Ctrl+Shift+U)"
                    MinWidth="90"
                    Padding="12,4"
                    Click="OnUnblockAll"/>
        </StackPanel>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    Margin="0,0,0,10">
            <Button x:Name="editIpsButton"
                    Content="Edit IPs..."
                    MinWidth="90"
                    Padding="12,4"
                    Margin="0,0,8,0"
                    Click="OnEditIps"/>
            <Button x:Name="openFolderButton"
                    Content="Open Servers Folder"
                    MinWidth="130"
                    Padding="12,4"
                    Click="OnOpenServersFolder"/>
        </StackPanel>

        <TextBlock x:Name="blockedSummaryText"
                   Grid.Row="4"
                   Margin="0,0,0,8"
                   TextWrapping="Wrap"
                   Foreground="#FF555555"/>

        <Border Grid.Row="5"
                Padding="8,6"
                Background="#FFF5F5F5"
                BorderBrush="#FFE0E0E0"
                BorderThickness="1"
                CornerRadius="4">
            <TextBlock x:Name="statusText"
                       Text="Ready."
                       TextWrapping="Wrap"/>
        </Border>
    </Grid>
</Window>
