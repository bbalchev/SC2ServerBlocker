<Window x:Class="SC2ServerBlocker.ServerIpEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Server IPs"
        Height="420"
        Width="520"
        MinHeight="360"
        MinWidth="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Margin="0,0,8,0"
                       VerticalAlignment="Center"
                       Text="Region:"/>
            <ComboBox x:Name="regionCombo"
                      Grid.Column="1"
                      SelectionChanged="OnRegionSelectionChanged"/>
        </Grid>

        <TextBlock x:Name="regionLabel"
                   Grid.Row="1"
                   Margin="0,0,0,8"
                   TextWrapping="Wrap"/>

        <ListBox x:Name="ipList"
                 Grid.Row="2"
                 Margin="0,0,0,8"/>

        <Grid Grid.Row="3" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="newIpTextBox"
                     Grid.Column="0"
                     Margin="0,0,8,0"
                     VerticalContentAlignment="Center"
                     KeyDown="OnNewIpKeyDown"/>
            <Button Grid.Column="1"
                    Content="Add"
                    MinWidth="70"
                    Padding="10,4"
                    Click="OnAddIp"/>
        </Grid>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,12">
            <Button Content="Remove Selected"
                    MinWidth="110"
                    Padding="10,4"
                    Margin="0,0,8,0"
                    Click="OnRemoveSelected"/>
            <Button Content="Open Servers Folder"
                    MinWidth="130"
                    Padding="10,4"
                    Click="OnOpenFolder"/>
        </StackPanel>

        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Save"
                    MinWidth="80"
                    Padding="10,4"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="OnSave"/>
            <Button Content="Cancel"
                    MinWidth="80"
                    Padding="10,4"
                    IsCancel="True"
                    Click="OnCancel"/>
        </StackPanel>
    </Grid>
</Window>
